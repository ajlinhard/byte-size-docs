{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TerraformDynamoDBAdmin",
      "Effect": "Allow",
      "Action": [
        "dynamodb:CreateTable",
        "dynamodb:DeleteTable",
        "dynamodb:DescribeTable",
        "dynamodb:UpdateTable",
        "dynamodb:ListTables",
        "dynamodb:TagResource",
        "dynamodb:UntagResource",
        "dynamodb:ListTagsOfResource"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:YOUR_ACCOUNT_ID:table/terraform-state-lock"
    },
    {
      "Sid": "TerraformDynamoDBListAll",
      "Effect": "Allow",
      "Action": "dynamodb:ListTables",
      "Resource": "*"        
    },
    {
      "Sid": "TerraformStateLockDynamoDB",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:YOUR_ACCOUNT_ID:table/terraform-state-lock"
    }
    {
      "Sid": "S3FullAccess",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": ["arn:aws:s3:::*", "arn:aws:s3:::*/*"]
    },
    {
      "Sid": "ECSFullAccess",
      "Effect": "Allow",
      "Action": ["ecs:*", "ecr:*"],
      "Resource": "*"
    },
    {
      "Sid": "SQSFullAccess",
      "Effect": "Allow",
      "Action": ["sqs:*"],
      "Resource": "*"
    },
    {
      "Sid": "SNSFullAccess",
      "Effect": "Allow",
      "Action": ["sns:*"],
      "Resource": "*"
    },
    {
      "Sid": "RDSFullAccess",
      "Effect": "Allow",
      "Action": ["rds:*", "rds-db:*", "rds-data:*"],
      "Resource": "*"
    },
    {
      "Sid": "RestrictedPassRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::619071338293:role/terraform-*"
      // Only pass roles that start with "terraform-"
    },
    {
      "Sid": "STSCallerIdentityAndServiceLinkedRoles",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity",
        "iam:CreateServiceLinkedRole",
        "iam:DeleteServiceLinkedRole",
        "iam:GetServiceLinkedRoleDeletionStatus"
      ],
      "Resource": "*"
    },
    {
      "Sid": "SecretsManagerAccess",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "KinesisFullAccess",
      "Effect": "Allow",
      "Action": ["kinesis:*", "firehose:*"],
      "Resource": "*"
    },
    {
      "Sid": "EventBridgeFullAccess",
      "Effect": "Allow",
      "Action": ["events:*", "scheduler:*", "pipes:*"],
      "Resource": "*"
    },
    {
      "Sid": "CloudWatchFullAccess",
      "Effect": "Allow",
      "Action": ["cloudwatch:*", "logs:*", "xray:*"],
      "Resource": "*"
    },
    {
      "Sid": "QuickSightFullAccess",
      "Effect": "Allow",
      "Action": ["quicksight:*"],
      "Resource": "*"
    },
    {
      "Sid": "LambdaFullAccess",
      "Effect": "Allow",
      "Action": ["lambda:*"],
      "Resource": "*"
    },
    {
      "Sid": "SageMakerFullAccess",
      "Effect": "Allow",
      "Action": ["sagemaker:*"],
      "Resource": "*"
    },
    {
      "Sid": "VPCFullAccess",
      "Effect": "Allow",
      "Action": ["ec2:*"],
      "Resource": "*"
    },
    {
    "Sid": "StepFunctionsFullAccess",
    "Effect": "Allow",
    "Action": ["states:*"],
    "Resource": "*"
    }
  ]
}
